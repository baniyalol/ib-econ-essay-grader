# Set ONE or more providers. The UI lets users pick which one to use.
# If a user pastes their own key in the UI, that key overrides these.

# --- Anthropic (Claude) — recommended, rubric calibrated against this ---
ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_EXEMPLAR_MODEL=   # optional; defaults to same as grading model

# --- OpenAI (GPT) ---
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o
# OPENAI_EXEMPLAR_MODEL=

# --- Google Gemini ---
# GEMINI_API_KEY=AIzaxxx
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_EXEMPLAR_MODEL=

# --- Safety knobs ---
# MAX_ESSAY_CHARS=12000
